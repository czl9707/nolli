{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nolli",
  "compatibility_date": "2026-06-01",
  "main": "src/worker.ts",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "DB_ORIGIN": "https://db.nolli-map.com"
  }
}
