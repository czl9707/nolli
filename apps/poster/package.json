{
  "name": "poster",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run generate:patterns && vite build",
    "generate:patterns": "tsx --tsconfig tsconfig.vite.json ../../packages/map/scripts/generate-patterns.ts",
    "typecheck": "tsc -p tsconfig.vite.json --noEmit",
    "lint": "eslint",
    "test": "vitest run"
  },
  "dependencies": {
    "@nolli/data": "workspace:*",
    "@nolli/map": "workspace:*",
    "@nolli/ui": "workspace:*",
    "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
    "framer-motion": "^12.42.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.25.0",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@csstools/postcss-global-data": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "better-sqlite3": "^12.10.0",
    "eslint": "^10.7.0",
    "postcss": "^8",
    "postcss-custom-media": "^12.0.1",
    "postcss-custom-properties": "^15.0.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
