{
  "name": "nolli",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "npm run generate:patterns && vite build",
    "generate:patterns": "tsx --tsconfig tsconfig.vite.json scripts/generate-patterns.ts",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "bake": "tsx scripts/bake-sqlite.ts",
    "bake:dry": "tsx scripts/bake-sqlite.ts --dry-run",
    "seed": "tsx scripts/seed-architectures.ts",
    "seed:dry": "tsx scripts/seed-architectures.ts --dry-run",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && wrangler dev"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/architects-daughter": "^5.2.7",
    "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
    "arctic": "^3.7.0",
    "cmdk": "^1.1.1",
    "cookie": "^1.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "maplibre-gl": "^5.24.0",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-router": "^7.15.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "supercluster": "^8.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1056.0",
    "@cloudflare/vite-plugin": "^1.39.0",
    "@cloudflare/workers-types": "^4.20260608.1",
    "@csstools/postcss-global-data": "^4.0.0",
    "@eslint/eslintrc": "^3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supercluster": "^7.1.3",
    "@vitejs/plugin-react": "^6.0.2",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "postcss": "^8",
    "postcss-custom-media": "^12.0.1",
    "postcss-custom-properties": "^15.0.1",
    "prettier": "^3.8.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.13",
    "wrangler": "^4.95.0"
  }
}
