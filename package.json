{
  "name": "nolli",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "npm run generate:patterns && vite build",
    "generate:patterns": "tsx scripts/generate-patterns.ts",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "seed": "tsx scripts/seed-architectures.ts",
    "seed:dry": "tsx scripts/seed-architectures.ts --dry-run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1056.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/architects-daughter": "^5.2.7",
    "@supabase/supabase-js": "^2.106.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "maplibre-gl": "^5.24.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.15.1",
    "sharp": "^0.34.5",
    "supercluster": "^8.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@csstools/postcss-global-data": "^4.0.0",
    "@eslint/eslintrc": "^3",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supercluster": "^7.1.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "postcss": "^8",
    "postcss-custom-media": "^12.0.1",
    "postcss-custom-properties": "^15.0.1",
    "prettier": "^3.8.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.13"
  }
