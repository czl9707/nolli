{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["esnext"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "types": ["@cloudflare/workers-types", "vite/client"],
    "paths": {
      "@worker/*": ["./worker/*"]
    }
  },
  "include": ["worker/**/*.ts"],
  "exclude": ["node_modules"]
}
